# Landing Reply — Frontend environment
# Copy to .env.local

# Backend API URL
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# VPS deploy (replace with your server IP or domain):
# NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000

# Site URL used for landing page links in reply variants
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# VPS:
# NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP:3000
